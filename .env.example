# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# 32-byte key for AES-GCM credential encryption.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY="replace-with-base64-32-byte-key"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-better-auth-secret"
BETTER_AUTH_URL="http://localhost:5173"

# Optional Google auth. Leave unset to disable the Google login button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
